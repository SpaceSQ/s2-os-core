{
  "name": "s2-space-agent-os",
  "version": "1.1.3",
  "description": "S2 Mothership [3.22 Native] - Spatial logic framework for Openclaw.",
  "main": "handler.py",
  "scripts": {
    "start": "python3 handler.py",
    "install": "pip install -r requirements.txt"
  },
  "openclaw": {
    "extensions": [
      "openclaw.plugin.json"
    ],
    "capabilities": ["spatial", "heartbeat", "actuator"],
    "compat": {
      "pluginApi": ">=3.22.0"
    }
  },
  "keywords": [
    "openclaw",
    "agent",
    "spatial",
    "s2"
  ],
  "author": "Space2.world",
  "license": "MIT"
}